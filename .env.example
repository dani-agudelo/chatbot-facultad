# Proveedor LLM: gemini | nvidia
LLM_PROVIDER=nvidia

# Claves API: preferibles desde el panel (Configuracion, cifradas en BD).
# Si no estan en BD, se usan estas variables como fallback.
GEMINI_API_KEY=
NVIDIA_API_KEY=

# Modelo LLM (opcional; default segun proveedor)
# gemini  -> gemini-2.5-flash
# nvidia  -> meta/llama-3.1-8b-instruct
LLM_MODEL=meta/llama-3.1-8b-instruct

EMBED_MODEL=baai/bge-m3
EMBED_BATCH_SIZE=32

CHAT_SIMILARITY_TOP_K=5

CHAT_MEMORY_TOKEN_LIMIT=3500
SESSION_TTL_HOURS=24

LOG_RETENTION_DAYS=30

# ---- Panel de administracion ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/chatbot_admin
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
JWT_EXPIRE_HOURS=12
ADMIN_EMAIL=admin@facultad.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=Administrador Facultad
ADMIN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=25
