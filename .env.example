# Proveedor LLM: gemini | nvidia
LLM_PROVIDER=nvidia

# Claves API (GEMINI solo si LLM_PROVIDER=gemini; NVIDIA siempre para embeddings)
GEMINI_API_KEY=
NVIDIA_API_KEY=

# Modelo LLM (opcional; default segun proveedor)
# gemini  -> gemini-2.5-flash
# nvidia  -> meta/llama-3.1-8b-instruct
LLM_MODEL=meta/llama-3.1-8b-instruct

EMBED_MODEL=baai/bge-m3
EMBED_BATCH_SIZE=32

CHAT_SIMILARITY_TOP_K=5

CHAT_MEMORY_TOKEN_LIMIT=3500
SESSION_TTL_HOURS=24

LOG_RETENTION_DAYS=30
